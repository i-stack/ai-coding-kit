# Gateway server
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# ── LLM Provider Configuration ──────────────────────────────────────────────
# These keys are AUTO-SOURCED from env/gateway.json at the repo root.
# Edit that file (copy env/gateway.json.example first), then restart the gateway.
#
#   gateway.json key       →  process.env key (identity, no transform)
#   OPENAI_API_KEY         →  OPENAI_API_KEY
#   OPENAI_BASE_URL        →  OPENAI_BASE_URL
#   OPENAI_DEFAULT_MODEL   →  OPENAI_DEFAULT_MODEL
#   ANTHROPIC_API_KEY      →  ANTHROPIC_API_KEY
#   ANTHROPIC_BASE_URL     →  ANTHROPIC_BASE_URL
#
# To add a new provider (Google, Azure, Mistral, ...), simply add its
# key-value pair to env/gateway.json — no code changes needed in config.ts.
#
# Values set in THIS .env file take precedence over gateway.json.
# Uncomment and set any of the below to override for local testing:
#
#OPENAI_API_KEY=
#OPENAI_BASE_URL=
#OPENAI_DEFAULT_MODEL=
#ANTHROPIC_API_KEY=
#ANTHROPIC_BASE_URL=

# PostgreSQL transcript storage
DATABASE_URL=postgresql://localhost:5432/rag_gateway

# Qdrant semantic memory
QDRANT_URL=http://localhost:6333

# GraphRAG entity-relationship memory
GRAPH_RAG_ENABLED=true
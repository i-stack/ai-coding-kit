# Gateway server
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# Upstream LLM provider (OpenAI-compatible)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# Default model to use when client omits 'model' in the request
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic provider (optional - claude-* models route here when set)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# PostgreSQL transcript storage
DATABASE_URL=postgresql://localhost:5432/rag_gateway

# Qdrant semantic memory
QDRANT_URL=http://localhost:6333
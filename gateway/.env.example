# Gateway server
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# ── LLM Provider Configuration ──────────────────────────────────────────────
# These keys are AUTO-SOURCED from env/claude/settings.shared.json (the
# canonical source). Edit that file, then run: bash sync/sync_all.sh
#
#   shared.json key         →  process.env key(s)
#   ANTHROPIC_AUTH_TOKEN    →  OPENAI_API_KEY, ANTHROPIC_API_KEY
#   ANTHROPIC_BASE_URL      →  ANTHROPIC_BASE_URL
#   ANTHROPIC_BASE_URL+/v1  →  OPENAI_BASE_URL
#   ANTHROPIC_MODEL         →  OPENAI_DEFAULT_MODEL
#
# Values set in THIS .env file take precedence over shared.json.
# Uncomment and set any of the below to override for local testing:
#
#OPENAI_API_KEY=
#OPENAI_BASE_URL=
#OPENAI_DEFAULT_MODEL=
#ANTHROPIC_API_KEY=
#ANTHROPIC_BASE_URL=

# PostgreSQL transcript storage
DATABASE_URL=postgresql://localhost:5432/rag_gateway

# Qdrant semantic memory
QDRANT_URL=http://localhost:6333

# GraphRAG entity-relationship memory
GRAPH_RAG_ENABLED=true